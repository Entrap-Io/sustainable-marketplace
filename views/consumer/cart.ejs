<%- include('../partials/header', { title: 'Shopping Cart' }) %>
<div class="container mt-5">
  <h2 class="mb-4">Shopping Cart</h2>
  
  <div class="row">
    <div class="col-md-8">
      <% if (cartItems.length === 0) { %>
        <div class="alert alert-info">Your cart is empty.</div>
      <% } else { %>

        <div class="list-group" id="cart-list">
          <% cartItems.forEach(item => { %>
            <div class="list-group-item d-flex justify-content-between align-items-center cart-item" data-id="<%= item.cart_id %>" data-price="<%= item.discounted_price %>">
              <div class="d-flex align-items-center">
                <img src="/uploads/<%= item.image_filename %>" width="60" height="60" class="me-3 rounded" style="object-fit:cover;">
                <div>
                  <h6 class="mb-0"><%= item.title %></h6>
                  <small class="text-muted"><%= item.discounted_price %> TL each</small>
                </div>
              </div>

              <div class="d-flex align-items-center">
                <button class="btn btn-sm btn-outline-secondary cart-action" data-action="decrease">-</button>
                <span class="mx-2 item-quantity"><%= item.quantity %></span>
                <button class="btn btn-sm btn-outline-secondary cart-action" data-action="increase">+</button>
                <span class="mx-3 fw-bold item-total text-success" style="min-width: 80px;"><%= (item.discounted_price * item.quantity).toFixed(2) %> TL</span>
                <button class="btn btn-sm btn-danger cart-action" data-action="remove">Remove</button>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
    
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Order Summary</h5>
          <hr>
          <div class="d-flex justify-content-between mb-3">
            <span class="fw-bold">Grand Total:</span>
            <strong id="grand-total" class="fs-4 text-success">0.00 TL</strong>
          </div>
          <button id="purchase-btn" class="btn btn-success w-100 p-2 fw-bold" <%= cartItems.length === 0 ? 'disabled' : '' %>>PURCHASE</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body" id="toast-msg">Cart updated!</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const toastEl = document.getElementById("cartToast");
  const toastMsg = document.getElementById("toast-msg");
  const toast = new bootstrap.Toast(toastEl);
  
  function updateGrandTotal() {
    let total = 0;
    let count = 0;

    document.querySelectorAll(".cart-item").forEach(el => {
      const price = parseFloat(el.getAttribute("data-price"));
      const qty = parseInt(el.querySelector(".item-quantity").innerText);
      const itemTotal = price * qty;

      el.querySelector(".item-total").innerText = itemTotal.toFixed(2) + " TL";
      total += itemTotal;
      count += qty;
    });

    document.getElementById("grand-total").innerText = total.toFixed(2) + " TL";
    document.getElementById("cart-count").innerText = count > 0 ? count : "";
    document.getElementById("purchase-btn").disabled = (count === 0);
  }
  
  updateGrandTotal();

  document.querySelectorAll(".cart-action").forEach(btn => {
    btn.addEventListener("click", () => {
      const action = btn.getAttribute("data-action");
      const cartItemEl = btn.closest(".cart-item");
      const cartId = cartItemEl.getAttribute("data-id");

      fetch("/cart/update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ cart_id: cartId, action })
      }).then(r => r.json()).then(res => {
        if (res.success) {
          if (action === 'remove') {
            cartItemEl.remove();
          } else if (action === 'increase') {
            let qtyEl = cartItemEl.querySelector(".item-quantity");
            qtyEl.innerText = parseInt(qtyEl.innerText) + 1;
          } else if (action === 'decrease') {
            let qtyEl = cartItemEl.querySelector(".item-quantity");
            let newQty = parseInt(qtyEl.innerText) - 1;
            if (newQty <= 0) cartItemEl.remove();
            else qtyEl.innerText = newQty;
          }

          updateGrandTotal();
        }
      });
    });
  });

  document.getElementById("purchase-btn").addEventListener("click", () => {
    fetch("/cart/purchase", { method: "POST" })
    .then(r => r.json())
    .then(res => {
      if (res.success) {
        document.getElementById("cart-list").innerHTML = '<div class="alert alert-success">Purchase successful! Your items will be ready for pickup.</div>';
        updateGrandTotal();

        toastMsg.innerText = "Purchase completed successfully!";
        toast.show();
      }
    });
  });
});
</script>
<%- include('../partials/footer') %>
