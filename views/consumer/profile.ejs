<%- include('../partials/header', { title: 'Profile Settings' }) %>

<div class="container mt-5" style="max-width: 500px;">
  <h2 class="mb-4">Profile Settings</h2>

  <% if (message) { %>
    <div class="alert alert-success"><%= message %></div>
  <% } %>

  <form action="/consumer/profile" method="POST">
    
    <div class="mb-3">
      <label>Full Name</label>
      <input type="text" name="name" class="form-control" value="<%= data.name %>" required>
    </div>

    <div class="row mb-3">
      <div class="col">
        <label>City</label>
        <select name="city" class="form-select" data-current="<%= data.city %>" required>
          <option value="">Loading Cities...</option>
        </select>
      </div>

      <div class="col">
        <label>District</label>
        <select name="district" class="form-select" data-current="<%= data.district %>" required>
          <option value="">Select District</option>
        </select>
      </div>
    </div>
    <script src="/js/geo-selector.js"></script>

    <button type="submit" class="btn btn-primary w-100">Update Profile</button>
    <a href="/consumer/dashboard" class="btn btn-secondary w-100 mt-2">Back</a>
  </form>
</div>

<%- include('../partials/footer') %>
