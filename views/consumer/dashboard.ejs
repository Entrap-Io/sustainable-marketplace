<%- include('../partials/header', { title: 'Consumer Dashboard' }) %>
<div class="container mt-4">
  <div class="mb-4">
    <h2 class="fw-bold mb-1">Deals in <%= searchScope === 'city' ? cityName : districtName %></h2>
    <p class="text-muted">Save money, reduce waste.</p>
  </div>

  <!-- Scope Toggle -->
  <div class="mb-4 toggle">
    <div class="row g-2">
      <div class="col-6">
        <a href="/consumer/dashboard?searchScope=district&keyword=<%= keyword %>&sort=<%= sort %>" 
           class="btn w-100 <%= searchScope === 'district' ? 'btn-primary' : 'btn-outline-primary border-0 bg-white shadow-sm' %>">
          <i class="bi bi-geo-alt-fill me-1"></i> <%= districtName %> Only
        </a>
      </div>
      <div class="col-6">
        <a href="/consumer/dashboard?searchScope=city&keyword=<%= keyword %>&sort=<%= sort %>" 
           class="btn w-100 <%= searchScope === 'city' ? 'btn-primary' : 'btn-outline-primary border-0 bg-white shadow-sm' %>">
          <i class="bi bi-building me-1"></i> All of <%= cityName %>
        </a>
      </div>
    </div>
  </div>

  <!-- Search and Sort Row -->
  <form action="/consumer/dashboard" method="GET" class="mb-5">
    <input type="hidden" name="searchScope" value="<%= searchScope %>">
    <div class="row g-3 align-items-center">
      <div class="col-lg-7 col-md-6">
        <div class="input-group shadow-sm rounded">
          <input type="text" name="keyword" class="form-control border-0 py-2 ps-3" placeholder="What are you looking for?" value="<%= keyword %>">
          <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-search me-1"></i> Search
          </button>
        </div>
      </div>
      <div class="col-lg-3 col-md-4">
        <div class="d-flex align-items-center bg-white shadow-sm rounded px-2">
          <i class="bi bi-sort-down ms-2 text-muted"></i>
          <select name="sort" class="form-select border-0 bg-transparent py-2" onchange="this.form.submit()">
            <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="expiry_soon" <%= sort === 'expiry_soon' ? 'selected' : '' %>>Expiry: Soonest</option>
            <option value="discount_high" <%= sort === 'discount_high' ? 'selected' : '' %>>Highest Discount</option>
            <option value="name_asc" <%= sort === 'name_asc' ? 'selected' : '' %>>Name: A-Z</option>
          </select>
        </div>
      </div>
      <div class="col-lg-2 col-md-2 text-center text-md-end">
        <a href="/consumer/dashboard?searchScope=<%= searchScope %>" class="text-muted small text-decoration-none">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </a>
      </div>
    </div>
  </form>

  <div class="row">
    <% if (products.length === 0) { %>
      <div class="col-12 py-5 text-center">
        <div class="panel d-inline-block">
          <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
          <h4>No results found</h4>
          <p class="text-muted mb-0">Try adjusting your filters or search keywords.</p>
        </div>
      </div>
    <% } else { %>
      <% products.forEach(product => { %>
        <div class="col-xl-3 col-lg-4 col-sm-6 mb-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="position-relative">
              <img src="/uploads/<%= product.image_filename %>" class="card-img-top" alt="<%= product.title %>" style="height: 180px; object-fit: cover;">
              <%
                const discountPercent = Math.round(
                   ((product.normal_price - product.discounted_price) / product.normal_price) * 100
                );
              %>
              <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-danger rounded-pill shadow-sm">
                   -<%= discountPercent %>% OFF
                </span>
              </div>
            </div>
            
            <div class="card-body d-flex flex-column">
              <h6 class="card-title fw-bold mb-1 shortText" style="height: 2.4em;"><%= product.title %></h6>
              
              <p class="card-text small text-muted mb-3">
                <i class="bi bi-shop text-success me-1"></i> <%= product.market_name %> (<%= product.market_district %>)
              </p>

              <div class="mt-auto">
                <div class="mb-3">
                  <div class="d-flex align-items-baseline gap-2">
                    <span class="price fs-4"><%= product.discounted_price %> TL</span>
                    <del class="text-muted small"><%= product.normal_price %> TL</del>
                  </div>
                </div>
                
                <div class="d-flex flex-column gap-1 small">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-calendar-event me-1"></i> Expires:</span>
                    <span class="<%= product.days_left <= 2 ? 'text-danger fw-bold' : 'text-dark' %>">
                      <%= new Date(product.expiration_date).toLocaleDateString() %>
                    </span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-hourglass-split me-1"></i> Status:</span>
                    <span class="badge <%= product.days_left <= 2 ? 'bg-danger-subtle text-danger' : 'bg-warning-subtle text-dark' %> border-0">
                      <% if (product.days_left > 0) { %>
                        <%= product.days_left %> days left
                      <% } else { %>
                        Expires today!
                      <% } %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="card-footer bg-white border-0 p-3 pt-0">
              <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2 add-to-cart-btn" data-id="<%= product.id %>">
                <i class="bi bi-cart-plus-fill fs-5"></i> Add to Cart
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <nav class="mt-5 mb-5">
      <ul class="pagination justify-content-center">
        <% for(let i=1; i<=totalPages; i++) { %>
          <li class="page-item mx-1 <%= page === i ? 'active' : '' %>">
            <a class="page-link rounded-circle border-0 shadow-sm" href="/consumer/dashboard?page=<%= i %>&searchScope=<%= searchScope %>&keyword=<%= keyword %>&sort=<%= sort %>" style="width: 40px; height: 40px; line-height: 24px; text-align: center;">
              <%= i %>
            </a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
  
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="cartToast" class="toast align-items-center text-bg-success border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex p-2">
      <i class="bi bi-check-circle-fill me-2 ms-1"></i>
      <div class="toast-body fw-medium" id="toast-msg">Item added to your basket!</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const updateCartCount = () => {
    fetch("/cart/count").then(r => r.json()).then(data => {
      const countEl = document.getElementById("cart-count");
      if (countEl) {
        countEl.innerText = data.count > 0 ? data.count : "";
        countEl.style.display = data.count > 0 ? "block" : "none";
      }
    });
  };
  
  updateCartCount();

  const toastEl = document.getElementById("cartToast");
  const toastMsg = document.getElementById("toast-msg");
  const toast = new bootstrap.Toast(toastEl, { delay: 2000 });

  document.querySelectorAll(".add-to-cart-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const productId = btn.getAttribute("data-id");
      
      // Visual feedback
      const originalContent = btn.innerHTML;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Adding...';
      btn.disabled = true;

      fetch("/cart/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ product_id: productId })
      })
      .then(r => r.json())
      .then(res => {
        btn.innerHTML = originalContent;
        btn.disabled = false;
        if (res.success) {
          toastEl.classList.replace("text-bg-danger", "text-bg-success");
          toastMsg.innerText = "Item added to your basket!";
          toast.show();
          updateCartCount();
        } else {
          toastEl.classList.replace("text-bg-success", "text-bg-danger");
          toastMsg.innerText = res.error || "Could not add item.";
          toast.show();
        }
      })
      .catch(() => {
        btn.innerHTML = originalContent;
        btn.disabled = false;
      });
    });
  });
});
</script>

<%- include('../partials/footer') %>
