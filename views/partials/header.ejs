<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %> - Discount Marketplace</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
      <a class="navbar-brand" href="/">Discount Marketplace</a>

      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
            <% if (user && user.role === 'consumer') { %>
              <li class="nav-item"><a class="nav-link" href="/cart">Cart <span id="cart-count" class="badge bg-secondary"></span></a></li>
            <% } %>
            <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout (<%= user.name %>)</a></li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
