<%- include('../partials/header', { title: 'Market Dashboard' }) %>
  <div class="container mt-4">

    <div class="panel border-0 mb-5 py-4">
      <div class="row align-items-center">
        <div class="col-md-6">
          <h2 class="fw-bold mb-1">Market Inventory</h2>
          <p class="text-muted mb-0">Manage your listings and track expirations.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0 d-flex flex-wrap justify-content-md-end gap-2">
          <form action="/market/dashboard" method="GET"
            class="d-flex align-items-center bg-white border rounded px-2 shadow-sm me-md-2">
            <i class="bi bi-sort-down text-muted ms-1"></i>
            <select name="sort" class="form-select border-0 bg-transparent form-select-sm py-2"
              style="min-width: 160px;" onchange="this.form.submit()">
              <option value="newest" <%=typeof sort !=='undefined' && sort==='newest' ? 'selected' : '' %>>Newest First
              </option>
              <option value="expiry_soon" <%=typeof sort !=='undefined' && sort==='expiry_soon' ? 'selected' : '' %>
                >Expiry: Soonest</option>
              <option value="stock_low" <%=typeof sort !=='undefined' && sort==='stock_low' ? 'selected' : '' %>>Stock:
                Lowest</option>
              <option value="stock_high" <%=typeof sort !=='undefined' && sort==='stock_high' ? 'selected' : '' %>
                >Stock: Highest</option>
              <option value="price_high" <%=typeof sort !=='undefined' && sort==='price_high' ? 'selected' : '' %>
                >Price: Highest</option>
              <option value="name_asc" <%=typeof sort !=='undefined' && sort==='name_asc' ? 'selected' : '' %>>Name: A-Z
              </option>
            </select>
          </form>
          <a href="/market/product/add" class="btn btn-primary d-flex align-items-center shadow-sm">
            <i class="bi bi-plus-circle-fill me-2 fs-5"></i> Add New Product
          </a>
        </div>
      </div>
    </div>

    <div class="row">
      <% if (products.length===0) { %>
        <div class="col-12 text-center py-5">
          <div class="panel border-0 d-inline-block">
            <i class="bi bi-box-seam fs-1 text-muted mb-3 d-block"></i>
            <h4>Your shop is empty</h4>
            <p class="text-muted mb-3">Start adding products to help reduce food waste.</p>
            <a href="/market/product/add" class="btn btn-primary px-4">Add Your First Product</a>
          </div>
        </div>
        <% } else { %>
          <% products.forEach(product=> { %>
            <div class="col-xl-4 col-lg-6 mb-4">
              <div
                class="card h-100 shadow-sm border-0 position-relative overflow-hidden <%= product.is_expired ? 'bg-light' : '' %>">
                <div class="row g-0 h-100">
                  <div class="col-4 position-relative">
                    <img src="/uploads/<%= product.image_filename %>" class="img-fluid h-100 w-100"
                      alt="<%= product.title %>" style="object-fit: cover; min-height: 180px;">
                    <div class="position-absolute top-0 end-0 m-2">
                      <span class="badge <%= product.stock < 5 ? 'bg-danger' : 'bg-dark' %> shadow-sm">
                        <%= product.stock %> in stock
                      </span>
                    </div>
                    <% if (product.is_expired) { %>
                      <div class="position-absolute top-0 start-0 w-100 h-100 bg-danger opacity-25"></div>
                      <div class="position-absolute top-0 start-0 m-2">
                        <span class="badge bg-danger">EXPIRED</span>
                      </div>
                      <% } %>
                  </div>
                  <div class="col-8">
                    <div class="card-body d-flex flex-column h-100 p-3">
                      <h6 class="card-title fw-bold shortText mb-2">
                        <%= product.title %>
                      </h6>

                      <div class="mb-3 d-flex flex-wrap gap-1">
                        <% const discountPercent=Math.round(((product.normal_price - product.discounted_price) /
                          product.normal_price) * 100); %>
                          <span class="badge bg-success-subtle text-success border-0 small">-<%= discountPercent %>%
                              OFF</span>
                          <% if (!product.is_expired) { %>
                            <span
                              class="badge <%= product.days_left <= 2 ? 'bg-danger-subtle text-danger' : 'bg-warning-subtle text-dark' %> border-0 small">
                              <%= product.days_left %>d left
                            </span>
                            <% } %>
                      </div>

                      <div class="mt-auto">
                        <div class="mb-3">
                          <div class="d-flex align-items-baseline gap-2">
                            <span class="h5 fw-bold text-success mb-0">
                              <%= product.discounted_price %> TL
                            </span>
                            <span class="text-muted text-decoration-line-through small">
                              <%= product.normal_price %> TL
                            </span>
                          </div>
                        </div>

                        <div class="d-flex gap-2">
                          <a href="/market/product/edit/<%= product.id %>"
                            class="btn btn-outline-primary btn-sm flex-grow-1 border-0 bg-light">
                            <i class="bi bi-pencil-square"></i> Edit
                          </a>
                          <form action="/market/product/delete/<%= product.id %>" method="POST" class="flex-grow-1">
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100 border-0 bg-light"
                              onclick="return confirm('Delete this listing?')">
                              <i class="bi bi-trash3"></i> Delete
                            </button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <% }) %>
              <% } %>
    </div>
  </div>
  <%- include('../partials/footer') %>