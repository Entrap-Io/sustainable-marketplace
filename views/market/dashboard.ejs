<%- include('../partials/header', { title: 'Market Dashboard' }) %>
<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Products</h2>
    <div>
      <a href="/market/profile" class="btn btn-secondary me-2">Profile Settings</a>
      <a href="/market/product/add" class="btn btn-success">Add New Product</a>
    </div>
  </div>
  
  <div class="row">
    <% if (products.length === 0) { %>
      <div class="col-12"><div class="alert alert-info">You have not added any products yet.</div></div>
    <% } else { %>
      <% products.forEach(product => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 <%= product.is_expired ? 'border-danger border-2' : '' %>">
            <img src="/uploads/<%= product.image_filename %>" class="card-img-top" alt="<%= product.title %>" style="height: 200px; object-fit: cover;">
            <div class="card-body">
              <h5 class="card-title"><%= product.title %></h5>
              
              <% if (product.is_expired) { %>
                <span class="badge bg-danger mb-2">EXPIRED</span>
              <% } else { %>
                <p class="card-text small text-warning">
                  <%= product.days_left %> days left
                </p>
              <% } %>

              <%
                const discountPercent = Math.round(((product.normal_price - product.discounted_price) / product.normal_price) * 100);
               %>

              <span class="badge bg-success">-<%= discountPercent %>%</span>
              <p class="card-text">
                <strong>Stock:</strong> <%= product.stock %><br>
                <strong>Price:</strong> <del><%= product.normal_price %> TL</del> <span class="text-success fw-bold"><%= product.discounted_price %> TL</span><br>
                <strong>Expires:</strong> <%= new Date(product.expiration_date).toLocaleDateString() %>
              </p>
            </div>
            <div class="card-footer bg-transparent">
              <a href="/market/product/edit/<%= product.id %>" class="btn btn-primary btn-sm">Edit</a>
              <form action="/market/product/delete/<%= product.id %>" method="POST" class="d-inline">
                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
